OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# WordPress settings
WP_URL=https://example.com
WP_USER=your_wp_username
WP_APP_PASSWORD=your_app_password
WP_STATUS=draft

# Post mode: queue = enqueue only, direct = post to WordPress immediately
POST_MODE=queue
# When POST_MODE=queue, how many queued posts to publish per run
POSTS_PER_RUN=1

# Control how many articles to generate / post
MAX_KEYWORDS=3
ENABLE_COMPARE_POST=true
ENABLE_PRODUCT_POST=false
ENABLE_VERSUS_POST=false
MAX_COMPARE_POSTS=1
MAX_PRODUCT_POSTS=0
MAX_VERSUS_POSTS=0

